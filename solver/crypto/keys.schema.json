{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "description",
    "version",
    "default",
    "keys"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "default": {
      "type": "string",
      "description": "UUID7 of the default key, must exist in keys"
    },
    "keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "value",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{32}$",
            "description": "hex-encoded UUID7"
          },
          "value": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{64}$",
            "description": "hex-encoded 256-bit AES key"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "retired"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
