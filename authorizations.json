{
  "profiles": {
    "reader": {
      "inherits": null,
      "grants": ["solver:execute", "solutions:read", "docs:read", "web-content:read", "users:read"]
    },
    "contributor": {
      "inherits": "reader",
      "grants": ["solutions:write", "solutions:execute"]
    },
    "maintainer": {
      "inherits": "contributor",
      "grants": ["solutions:delete", "ai:execute"]
    },
    "admin": {
      "inherits": "maintainer",
      "grants": ["shell:execute", "infra:execute", "users:write"]
    }
  },
  "users": {},
  "objects": {
    "solutions": ["solutions/"],
    "docs": ["docs/"],
    "web-content": ["web-content/"],
    "solver": [],
    "shell": ["/bin/bash"],
    "ai": [],
    "users": [],
    "infra": []
  }
}
